# ============================================================
# JNH OPS PLATFORM — Environment Variables
# Copy this file to .env.local and fill in your values.
# Get Supabase values from: Dashboard > Project Settings > API
# ============================================================

# ------ SUPABASE (Client-side, safe to expose) ------
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ------ ANTHROPIC (SERVER-SIDE ONLY) ------
# ⚠️  DO NOT put this in .env.local — it would be bundled into the client!
# Store this as a Supabase Edge Function secret instead:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ------ N8N WEBHOOK SECRET (SERVER-SIDE ONLY) ------
# ⚠️  DO NOT put this in .env.local — it would be bundled into the client!
# Store this as a Supabase Edge Function secret instead:
#   supabase secrets set N8N_WEBHOOK_SECRET=your-secret-here
# Generate a strong random secret, e.g.: openssl rand -hex 32
# Use the exact same value in your n8n webhook node's Authorization header.
N8N_WEBHOOK_SECRET=your-strong-random-secret-here
